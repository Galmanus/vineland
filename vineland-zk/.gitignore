# keep: circuits/, contract/src, *.circom, vk*.json, proof*.json, public*.json, input*.json, *.sh, *.md, Dockerfile.prover

# real-batch private witness (amounts+recipients) — never commit
build_real/input.json
build_real/*.wtns
/tmp/real_orders.json

# shadow attester: private witnesses; keep attestations.jsonl + public proofs
build_attest/*/input.json
build_attest/*/*.wtns
/tmp/all_orders.json
/tmp/all_merchants.json

# KYC circuit private witnesses (birthYear, sanctionId, secrets)
build_kyc/input*.json
build_kyc/*.wtns
