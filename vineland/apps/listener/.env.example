# vineland-listener · required env vars
# Set via `flyctl secrets set KEY=value` for staging/prod.

# Supabase project URL + service-role key (NEVER expose to client)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Stellar network: TESTNET | PUBLIC
STELLAR_NETWORK=TESTNET

# How often the manager re-reads the active merchants list (ms).
# Lower = streams open faster for newly-added merchants; higher = less DB pressure.
MERCHANT_POLL_MS=30000

# Optional: override the USDC issuer the matcher expects.
# Used by the e2e test to mint custom test USDC. Leave unset in real testnet/prod.
# STELLAR_USDC_ISSUER_OVERRIDE=
