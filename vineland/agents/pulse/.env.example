SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

PULSE_TELEGRAM_TOKEN=your-telegram-bot-token
# comma-separated chat IDs — Manuel + Mario
PULSE_TELEGRAM_CHAT_IDS=your_chat_id

# Optional: on first run, scan this many hours back. 0 (default) = start fresh.
# Use e.g. 24 if Pulse was down for 24h and you want to catch up.
PULSE_BACKFILL_HOURS=0
