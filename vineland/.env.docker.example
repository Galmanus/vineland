# Vineland docker-compose env template.
#   cp .env.docker.example .env.docker
#   docker compose --env-file .env.docker up --build

# ─── Supabase (hosted or local stack via `supabase start`) ────────────
SUPABASE_URL=https://aaiiwhmthjtkcartzmku.supabase.co
SUPABASE_ANON_KEY=eyJ...                          # publishable
SUPABASE_SERVICE_ROLE_KEY=eyJ...                  # secret — listener + api server-side only
VINELAND_DB_SCHEMA=vineland

# ─── Web build-time vars (Vite inlines into bundle) ──────────────────
VITE_SUPABASE_URL=https://aaiiwhmthjtkcartzmku.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
VITE_API_BASE=http://localhost:8000/api           # change to the public api host in prod
VITE_STELLAR_NETWORK=TESTNET
VITE_PLATFORM_ADDRESS=G...                        # platform stellar testnet pubkey

# ─── Listener ─────────────────────────────────────────────────────────
STELLAR_NETWORK=TESTNET
MERCHANT_POLL_MS=30000

# ─── API ──────────────────────────────────────────────────────────────
CHECKOUT_BASE_URL=http://localhost:5173
RATE_BRL_USDC=                                    # set to a fixed BRL/USDC for tests; leave empty to use CoinGecko

# ─── Host ports (change if conflicting locally) ──────────────────────
WEB_PORT=5173
API_PORT=8000
