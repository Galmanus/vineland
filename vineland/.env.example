# Vineland top-level .env.example
#
# Authoritative list of every environment variable read by ecosystem.config.cjs
# (PM2 listener+api on the VPS) and supabase/functions/api/* (Hono routes).
# Per-app .env.example files (apps/{web,listener}/.env.example, agents/pulse/...)
# stay narrower for local dev.
#
# Audit-005 · S7: keep this file in sync with ecosystem.config.cjs + lib/* env reads.
# A missing variable here that prod uses == operator deploys with a hole.

# ── Stellar network ──────────────────────────────────────────────────────────
# "testnet" or "mainnet". The listener gates SSRF hardening + USDC issuer +
# Horizon URL by this.
STELLAR_NETWORK=testnet

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://aaiiwhmthjtkcartzmku.supabase.co
# anon key is publishable; service role is server-only
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# default "public" — change only if you know why
VINELAND_DB_SCHEMA=public

# ── API process ──────────────────────────────────────────────────────────────
API_PORT=8080
# Used by orders.ts + subscriptions.ts to build checkout_url
CHECKOUT_BASE_URL=https://api.vineland.cc

# Audit-004 · C2: HMAC secret that signs the `?t=` token on every
# checkout_url. Required, ≥32 chars. Rotate by re-issuing checkout URLs.
CHECKOUT_TOKEN_SECRET=

# Audit-004 · C4: server-side pepper for HMAC-SHA-256(plain) → api_key_hash.
# A DB-only leak (Supabase breach, backup theft, support read access) is not
# enough to brute-force a key without this. Required, ≥32 chars. Rotation
# requires re-hashing all stored hashes (writes to merchants table).
API_KEY_PEPPER=

# Optional. "1" echoes Zod validation issues to API callers; default terse.
# Useful in staging, turn OFF in prod.
ZOD_VERBOSE=

# ── Listener process ─────────────────────────────────────────────────────────
# How often the manager polls merchants table for desired stream set.
MERCHANT_POLL_MS=15000
# Optional override of USDC SAC. NEVER set on mainnet — listener refuses to
# accept this on PUBLIC network (audit-003 L14).
STELLAR_USDC_ISSUER_OVERRIDE=
# Optional override of FX BRL/USDC rate; bypasses CoinGecko if set.
RATE_BRL_USDC=
# Optional stable id for this listener instance. Defaults to a fresh uuid per
# boot (audit-003 L2 lease holder identity).
LISTENER_HOLDER_ID=

# ── Ask Vineland engine (concierge route) ─────────────────────────────────────
# Audit-004 · C7: spawn target. Bind HOME explicitly in prod; do not rely on
# defaults that point at developer paths.
HOME=/home/manuel
# Path to claude binary (defaults to "claude" on PATH).
CLAUDE_BIN=
# OAuth token for Max plan inference (preferred). Fallback: ANTHROPIC_API_KEY.
CLAUDE_CODE_OAUTH_TOKEN=
CLAUDE_CWD=
VINELAND_CONCIERGE_AUDIT=agents/concierge/concierge_audit.jsonl
VINELAND_CONCIERGE_SSL=
VINELAND_DOCS_BUNDLE=
VINELAND_DOCS_ROOT=

# ── Web (static) ────────────────────────────────────────────────────────────
# Where Hono serves apps/web/dist from. Set if not next to the api process.
WEB_DIST=

# ── PM2 / OS ─────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=production
